{
  "name": "opensdd-check",
  "private": true,
  "version": "3.3.0",
  "description": "OpenSDD project structure validator — checks SPEC.md, ARCHITECTURE.md, PLAN.md, AGENTS.md and module integrity for OpenSDD topology compliance",
  "type": "commonjs",
  "bin": {
    "opensdd-check": "index.js"
  },
  "scripts": {
    "test": "node --test",
    "test:coverage": "node --experimental-test-coverage --test",
    "lint": "eslint .",
    "format": "prettier --write \"**/*.js\"",
    "format-check": "prettier --check \"**/*.js\""
  },
  "files": [
    "index.js",
    "checks/",
    "lib/"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=22"
  },
  "devDependencies": {
    "eslint": "^9.39.4",
    "eslint-plugin-jsdoc": "^63.0.6",
    "prettier": "^3.0.0"
  },
  "dependencies": {
    "js-yaml": "^4.2.0"
  }
}
